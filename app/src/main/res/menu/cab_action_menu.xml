<?xml version="1.0" encoding="utf-8"?>
<menu xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Selection actions live on the bottom MRippleToolBar (txDial pattern); top bar is title + select-all only. -->
    <item
        android:id="@+id/cab_select_all"
        android:icon="@drawable/ic_cmn_select_none"
        android:title="@string/select_all"
        app:showAsAction="always" />

    <!-- Keep id for adapters that reference R.id.cab_delete; not shown on the top CAB. -->
    <item
        android:id="@+id/cab_delete"
        android:title="@string/delete"
        android:visible="false"
        app:showAsAction="never" />

</menu>
