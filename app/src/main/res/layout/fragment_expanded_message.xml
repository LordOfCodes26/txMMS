<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="@dimen/smaller_margin">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topDetailsLargeExpanded"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="4dp"
        android:paddingHorizontal="@dimen/tx_search_view_margin_right"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/expandedMinimizeButtonWrapper"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:translationZ="4dp"
            app:cardBackgroundColor="@color/tx_cardview_bg"
            app:cardCornerRadius="24dp"
            app:cardElevation="3px"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:strokeColor="@color/tx_popup_menu_border"
            app:strokeWidth="@dimen/cardview_stroke">

        <ImageView
            android:id="@+id/expandedMinimizeButton"
            android:layout_width="@dimen/ic_action_expanded"
            android:layout_height="@dimen/ic_action_expanded"
            android:src="@drawable/ic_cmn_minimize"
            android:foreground="@drawable/ripple_all_corners_56dp"
            android:contentDescription="@string/minimize_message"
            android:padding="@dimen/medium_margin"
            android:translationZ="4dp"
            app:tint="@color/tx_title_text" />

        </com.google.android.material.card.MaterialCardView>



        <com.goodwy.commons.views.MyTextView
            android:id="@+id/expandedThreadCharacterCounter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingStart="@dimen/small_margin"
            android:paddingEnd="@dimen/small_margin"
            android:text="60/1"
            android:textSize="@dimen/small_text_size"
            android:visibility="gone"
            android:translationZ="4dp"
            app:layout_constraintTop_toBottomOf="@+id/expandedThreadSendMessageWrapper"
            app:layout_constraintEnd_toEndOf="@+id/expandedThreadSendMessageWrapper"
            app:layout_constraintStart_toStartOf="@+id/expandedThreadSendMessageWrapper"
            tools:ignore="HardcodedText"
            tools:visibility="visible" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/expandedThreadSendMessageWrapper"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:translationZ="4dp"
            app:cardBackgroundColor="@color/tx_cardview_bg"
            app:cardCornerRadius="24dp"
            app:cardElevation="3px"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:strokeColor="@color/tx_popup_menu_border"
            app:strokeWidth="@dimen/cardview_stroke">

<!--        <LinearLayout-->
<!--            android:id="@+id/expandedThreadSendMessageWrapper"-->
<!--            android:layout_width="wrap_content"-->
<!--            android:layout_height="wrap_content"-->
<!--            android:orientation="horizontal"-->
<!--            android:translationZ="4dp"-->
<!--            app:layout_constraintTop_toTopOf="parent"-->
<!--            app:layout_constraintBottom_toBottomOf="parent"-->
<!--            app:layout_constraintEnd_toEndOf="parent" >-->

            <com.android.common.view.MImageButton
                android:id="@+id/expandedThreadSendMessage"
                android:layout_width="@dimen/ic_action_expanded"
                android:layout_height="@dimen/ic_action_expanded"
                android:padding="@dimen/medium_margin"
                android:src="@drawable/ic_cmn_sms_send"
                android:tint="@color/tx_title_text"
                android:foreground="@drawable/ripple_all_corners_56dp"
                android:contentDescription="@string/send_sms"
                android:translationZ="4dp" />

            <douglasspgyn.com.github.circularcountdown.CircularCountdown
                android:id="@+id/expandedThreadSendMessageCountdown"
                android:layout_width="@dimen/medium_icon_size"
                android:layout_height="@dimen/medium_icon_size"
                android:padding="@dimen/smaller_margin"
                android:visibility="gone"
                app:countdownBackgroundColor="?attr/colorControlNormal"
                app:countdownForegroundColor="?attr/colorPrimary"
                app:countdownTextColor="@color/tx_title_text"
                app:countdownTextSize="@dimen/tx_normal_text" />

            <com.goodwy.commons.views.MyTextView
                android:id="@+id/threadAvailableMessageCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:elevation="@dimen/cardview_default_elevation"
                android:layout_gravity="end|bottom"
                android:layout_marginBottom="@dimen/medium_margin"
                android:layout_marginEnd="@dimen/smaller_margin"
                android:textColor="@color/default_text_color"
                android:textSize="@dimen/tiny_text_size"
                android:visibility="visible"
                tools:text="20"
                tools:visibility="visible" />

        </com.google.android.material.card.MaterialCardView>


        <com.goodwy.commons.views.ContactAvatarView
            android:id="@+id/sender_photo_large_expanded"
            android:layout_width="@dimen/normal_icon_size"
            android:layout_height="@dimen/normal_icon_size"
            android:layout_marginTop="8dp"
            android:contentDescription="@string/conversation_details"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:visibility="gone"/>

        <com.goodwy.commons.views.MyTextView
            android:id="@+id/sender_name_large_expanded"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/ripple_all_corners"
            android:layout_marginTop="4dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:maxLines="2"
            android:gravity="start"
            android:textSize="@dimen/tx_app_title"
            app:layout_goneMarginTop="16dp"
            app:layout_constraintStart_toEndOf="@+id/expandedMinimizeButtonWrapper"
            app:layout_constraintTop_toBottomOf="@+id/sender_photo_large_expanded"
            tools:text="Name"/>

        <com.goodwy.commons.views.MyTextView
            android:id="@+id/sender_number_large_expanded"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/ripple_all_corners"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:maxLines="1"
            android:alpha="0.8"
            android:gravity="start"
            android:textSize="@dimen/tx_small_text"
            app:layout_constraintStart_toEndOf="@+id/expandedMinimizeButtonWrapper"
            app:layout_constraintTop_toBottomOf="@+id/sender_name_large_expanded"
            tools:text="+12345678"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <FrameLayout
        android:id="@+id/topDetailsCompactExpanded"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="gone">

        <include layout="@layout/top_view" />

        <ImageView
            android:id="@+id/expandedMinimizeButtonCompact"
            android:layout_width="@dimen/medium_icon_size"
            android:layout_height="@dimen/medium_icon_size"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="4dp"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="@string/minimize_message"
            android:padding="@dimen/smaller_margin"
            android:src="@drawable/ic_chevron_down_vector" />

        <com.goodwy.commons.views.MyTextView
            android:id="@+id/expandedThreadCharacterCounterCompact"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/thread_background"
            android:gravity="center"
            android:paddingStart="@dimen/small_margin"
            android:paddingEnd="@dimen/small_margin"
            android:text="160/1"
            android:textSize="@dimen/small_text_size"
            android:visibility="gone"
            android:layout_gravity="end|top"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="4dp"
            tools:ignore="HardcodedText"
            tools:visibility="visible" />

        <LinearLayout
            android:id="@+id/expandedThreadSendMessageWrapperCompact"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="@dimen/tx_cardview_margin_vertical"
            android:background="?selectableItemBackgroundBorderless" >

            <ImageView
                android:id="@+id/expandedThreadSendMessageCompact"
                android:layout_width="@dimen/add_icon_size"
                android:layout_height="@dimen/add_icon_size"
                android:layout_gravity="center"
                android:foregroundGravity="center"
                android:background="@drawable/ic_sms_send"
                android:clickable="false"
                android:contentDescription="@string/ok"
                android:layout_marginStart="@dimen/small_margin" />

            <douglasspgyn.com.github.circularcountdown.CircularCountdown
                android:id="@+id/expandedThreadSendMessageCountdownCompact"
                android:layout_width="@dimen/medium_icon_size"
                android:layout_height="@dimen/medium_icon_size"
                android:visibility="gone"
                app:countdownBackgroundColor="?attr/colorControlNormal"
                app:countdownForegroundColor="?attr/colorPrimary"
                app:countdownTextColor="?attr/colorPrimary"
                app:countdownTextSize="24sp" />
        </LinearLayout>
    </FrameLayout>

    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/threadDetailsBarrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="topDetailsLargeExpanded,topDetailsCompactExpanded" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/expanded_message_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingStart="@dimen/normal_margin"
        android:paddingEnd="@dimen/normal_margin"
        android:paddingBottom="@dimen/normal_margin"
        app:layout_constraintTop_toBottomOf="@+id/threadDetailsBarrier"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.goodwy.commons.views.MyEditText
            android:id="@+id/expandedThreadTypeMessage"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@android:color/transparent"
            android:gravity="top|start"
            android:hint="@string/type_a_message"
            android:inputType="textCapSentences|textMultiLine"
            android:lineSpacingMultiplier="1.3"
            android:paddingStart="@dimen/normal_margin"
            android:paddingEnd="@dimen/normal_margin"
            android:paddingBottom="@dimen/normal_margin"
            android:scrollbars="vertical"
            android:fadeScrollbars="false"
            android:textColorHighlight="@color/tx_text_selection_highlight"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>

