<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/thread_attachment_wrapper"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/section_holder_stroke"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingEnd="@dimen/small_margin">

    <!--
        Left content area – matches Alps AudioAttachmentView:
        centered vertical stack of icon → filename → file size.
        The entire area is clickable to toggle playback.
    -->
    <FrameLayout
        android:id="@+id/audio_content_holder"
        android:layout_width="0dp"
        android:layout_height="@dimen/attachment_media_preview_height"
        android:layout_weight="1"
        android:foreground="@drawable/ripple_all_corners_16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/small_margin">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/audio_icon"
                android:layout_width="@dimen/big_icon_size"
                android:layout_height="@dimen/big_icon_size"
                android:scaleType="fitCenter"
                app:srcCompat="@drawable/ic_music_vector"
                tools:ignore="ContentDescription" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/filename"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/small_margin"
                android:ellipsize="middle"
                android:gravity="center_horizontal"
                android:maxLines="2"
                android:textSize="@dimen/normal_text_size"
                android:textStyle="bold"
                tools:text="voice_recording.ogg" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/file_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:textSize="@dimen/smaller_text_size"
                android:visibility="gone"
                tools:text="586 kB" />

        </LinearLayout>

        <!-- Small play/stop indicator at bottom-end corner -->
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/play_stop_icon"
            android:layout_width="@dimen/play_outline_size"
            android:layout_height="@dimen/play_outline_size"
            android:layout_gravity="bottom|end"
            android:layout_margin="@dimen/small_margin"
            android:alpha="0.7"
            android:src="@drawable/ic_vector_play_circle_outline"
            tools:ignore="ContentDescription" />

    </FrameLayout>

    <!-- Right action buttons – mirrors Alps play_audio_button / remove_audio_button -->
    <LinearLayout
        android:id="@+id/audio_attachment_actions"
        android:layout_width="@dimen/attachment_media_action_button_width"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/small_margin"
        android:paddingEnd="@dimen/tiny_margin">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/view_attachment_button"
            style="?android:attr/buttonStyleSmall"
            android:layout_width="match_parent"
            android:layout_height="@dimen/attachment_media_action_button_height"
            android:text="@string/play" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/remove_attachment_button"
            style="?android:attr/buttonStyleSmall"
            android:layout_width="match_parent"
            android:layout_height="@dimen/attachment_media_action_button_height"
            android:text="@string/remove_attachment" />

    </LinearLayout>

</LinearLayout>
