<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tx_common_bg">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:clipChildren="false"
        android:clipToPadding="false">

        <eightbitlab.com.blurview.BlurTarget
            android:id="@+id/mainBlurTarget"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/tx_common_bg"
            android:layout_marginTop="@dimen/tx_blur_target_margin_top"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <com.android.common.nestbouncy.BouncyScrollView
                android:id="@+id/nest_scroll"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:fillViewport="true"
                android:paddingHorizontal="@dimen/activity_padding_left_right"
                android:paddingTop="@dimen/tx_nest_bouncy_content_padding_top"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/storageLocationWrapper"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="@dimen/filter_section_margin">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/storageLocationCard"
                        style="@style/SettingsSectionHolder"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:id="@+id/storageLocationRows"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />

                    </androidx.cardview.widget.CardView>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:id="@+id/noSimPlaceholderImg"
                            android:layout_width="86dp"
                            android:layout_height="80dp"
                            android:layout_centerInParent="true"
                            android:contentDescription="@null"
                            android:gravity="center"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_no_sms"
                            android:visibility="visible" />

                        <com.goodwy.commons.views.MyTextView
                            android:id="@+id/noSimPlaceholder"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@+id/noSimPlaceholderImg"
                            android:layout_centerHorizontal="true"
                            android:gravity="center"
                            android:padding="@dimen/activity_margin"
                            android:text="@string/sim_card_not_available"
                            android:textColor="@color/txt_empty_sms"
                            android:textSize="@dimen/tx_sub_section"
                            android:visibility="visible" />
                    </RelativeLayout>

                </LinearLayout>
            </com.android.common.nestbouncy.BouncyScrollView>
        </eightbitlab.com.blurview.BlurTarget>

        <com.android.common.view.MVSideFrame
            android:id="@+id/m_vertical_side_frame_top"
            android:layout_width="match_parent"
            android:layout_height="@dimen/tx_mv_side_top_frame_height"
            android:layout_gravity="top"
            app:autoUpdate="false" />

        <com.android.common.view.MAppBarLayout
            android:id="@+id/sms_storage_location_appbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/tx_top_bar_expand_height"
            android:background="@color/transparent"
            app:elevation="0dp"
            app:liftOnScroll="false"
            app:titleText="@string/sms_storage_location" />

        <com.android.common.view.MVSideFrame
            android:id="@+id/m_vertical_side_frame_bottom"
            android:layout_width="match_parent"
            android:layout_height="@dimen/tx_mv_side_bottom_frame_height"
            android:layout_gravity="bottom"
            app:autoUpdate="false"
            app:isTopFrame="false" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

</FrameLayout>
