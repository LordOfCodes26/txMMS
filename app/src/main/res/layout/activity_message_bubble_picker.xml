<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tx_common_bg">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:clipChildren="false"
        android:clipToPadding="false">

        <eightbitlab.com.blurview.BlurTarget
            android:id="@+id/mainBlurTarget"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/tx_common_bg"
            android:layout_marginTop="@dimen/tx_blur_target_margin_top"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <com.goodwy.commons.views.MyRecyclerView
                android:id="@+id/bubblePickerList"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="true"
                android:paddingStart="@dimen/activity_margin"
                android:paddingTop="@dimen/tx_nest_bouncy_content_padding_top"
                android:paddingEnd="@dimen/activity_margin"
                android:scrollbars="none"
                app:layoutManager="com.goodwy.commons.views.MyLinearLayoutManager"
                tools:listitem="@layout/item_message_bubble_picker" />
        </eightbitlab.com.blurview.BlurTarget>

        <com.android.common.view.MVSideFrame
            android:id="@+id/m_vertical_side_frame_top"
            android:layout_width="match_parent"
            android:layout_height="@dimen/tx_mv_side_top_frame_height"
            android:layout_gravity="top"
            app:autoUpdate="false" />

        <com.android.common.view.MAppBarLayout
            android:id="@+id/bubblePickerAppbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/tx_top_bar_expand_height"
            android:background="@color/transparent"
            app:elevation="0dp"
            app:liftOnScroll="false"
            app:titleText="@string/speech_bubble" />

        <com.android.common.view.MVSideFrame
            android:id="@+id/m_vertical_side_frame_bottom"
            android:layout_width="match_parent"
            android:layout_height="@dimen/tx_mv_side_bottom_frame_height"
            android:layout_gravity="bottom"
            app:autoUpdate="false"
            app:isTopFrame="false" />
    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <com.android.common.view.MRippleToolBar
        android:id="@+id/confirm_tab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center|bottom"
        android:layout_centerHorizontal="true" />

