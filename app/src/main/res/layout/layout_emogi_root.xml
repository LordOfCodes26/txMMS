<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_emogi_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:visibility="visible">

    <LinearLayout
        android:id="@+id/main_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/layout_emogi_bottom_tab"
            android:layout_width="match_parent"
            android:layout_height="40.2dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:background="@color/read_bgcolor"
            android:paddingHorizontal="5dp">


        <RelativeLayout
                android:id="@+id/emogi_lay_start"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#00000000"
                android:orientation="vertical"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/emogi_iv_start"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_centerInParent="true"
                    android:scaleType="fitXY" />
            </RelativeLayout>

            <com.chutils.emo.views.PagerSlidingTabStrip
                android:id="@+id/emogi_tabs"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="5"
                app:pstsDividerPadding="0dp"
                app:pstsDividerWidth="0dp"
                app:pstsIndicatorHeight="0dp"
                app:pstsTabPaddingLeftRight="0dp" />

            <RelativeLayout
                android:id="@+id/emoji_lay_end"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:paddingLeft="@dimen/spacing_5"
                android:paddingRight="@dimen/spacing_5"
                android:clickable="true"
                android:orientation="vertical"
                >

                <ImageView
                    android:id="@+id/emoji_iv_end"
                    android:layout_width="@dimen/icon_size_xmiddle"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/spacing_4"
                    android:layout_centerInParent="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:adjustViewBounds="true"
                    android:src="@drawable/ic_action_backspace"
                    android:tint="@color/grey_80" />
            </RelativeLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_emoji_bottom_tab_top_line"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/grey_10"
            android:orientation="vertical"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"

            android:orientation="vertical">

            <androidx.viewpager.widget.ViewPager
                android:id="@+id/view_pager_emo"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>