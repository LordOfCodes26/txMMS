<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/thread_message_holder"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/small_margin"
    android:layout_marginBottom="@dimen/medium_normal_margin"
    android:foreground="@drawable/selector"
    android:paddingStart="@dimen/activity_margin"
    android:paddingEnd="@dimen/activity_margin">

    <RelativeLayout
        android:id="@+id/thread_message_wrapper"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.8">

        <ImageView
            android:id="@+id/threadMessageSenderPhoto"
            android:layout_width="@dimen/list_icon_size_medium"
            android:layout_height="@dimen/list_icon_size_medium"
            android:layout_alignBottom="@+id/threadMessageBodyWrapper"
            android:layout_alignParentStart="true"
            android:layout_marginEnd="@dimen/medium_margin"
            android:visibility="gone"
            tools:ignore="ContentDescription"
            tools:visibility="visible" />

        <LinearLayout
            android:id="@+id/thread_message_attachments_holder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@+id/threadMessageSenderPhoto"
            android:divider="@drawable/linear_layout_vertical_divider"
            android:orientation="vertical"
            android:showDividers="middle" />

        <ImageView
            android:id="@+id/thread_message_play_outline"
            android:layout_width="@dimen/play_outline_size"
            android:layout_height="@dimen/play_outline_size"
            android:layout_alignEnd="@+id/thread_message_attachments_holder"
            android:layout_alignBottom="@+id/thread_message_attachments_holder"
            android:layout_margin="@dimen/medium_margin"
            android:src="@drawable/ic_play_outline_vector"
            android:visibility="gone"
            tools:ignore="ContentDescription" />

        <LinearLayout
            android:id="@+id/threadMessageBodyWrapper"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/tiny_margin"
            android:layout_below="@+id/thread_message_attachments_holder"
            android:layout_toEndOf="@+id/threadMessageSenderPhoto"
            android:orientation="vertical">

            <TextView
                android:id="@+id/threadMessageSenderName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/normal_text_size"
                android:maxLines="1"
                android:visibility="gone"
                tools:visibility="visible"
                tools:text="Received message" />

            <TextView
                android:id="@+id/threadMessageBody"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/normal_text_size"
                tools:text="Received message" />

            <Space
                android:id="@+id/threadMessageBodySpacer"
                android:layout_width="match_parent"
                android:layout_height="@dimen/tx_cardview_summary_padding_top"
                android:layout_weight="1" />

            <LinearLayout
                android:id="@+id/threadMessageTimeSimHolder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="@dimen/tiny_margin">

                <ImageView
                    android:id="@+id/threadMessageStatusIcon"
                    android:layout_width="@dimen/normal_margin"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/small_margin"
                    android:visibility="gone"
                    android:src="@drawable/ic_check_vector"
                    tools:ignore="ContentDescription"
                    tools:visibility="visible" />
                <TextView
                    android:id="@+id/threadMessageTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/small_margin"
                    android:textSize="@dimen/smaller_text_size"
                    android:textColor="@color/tx_gray"
                    tools:text="14:30" />

                <ImageView
                    android:id="@+id/threadMessageSimIcon"
                    android:layout_width="@dimen/normal_activity_margin"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/small_margin"
                    android:visibility="gone"
                    android:src="@drawable/ic_sim_vector"
                    tools:ignore="ContentDescription"
                    tools:visibility="visible" />
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>

    <!-- Selection mode: same pattern as conversation list ([item_conversation]) — checkbox on the right, no full-row background. -->
    <com.android.common.view.MCycleCheckBox
        android:id="@+id/thread_message_checkbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="false"
        android:visibility="gone"
        android:layout_marginEnd="@dimen/smaller_margin"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
