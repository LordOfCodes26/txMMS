<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tx_common_bg"
    tools:context=".activities.RecipientSelectActivity">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:clipChildren="false"
        android:clipToPadding="false">

        <eightbitlab.com.blurview.BlurTarget
            android:id="@+id/mainBlurTarget"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/tx_common_bg"
            android:layout_marginTop="@dimen/tx_blur_target_margin_top"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <androidx.viewpager.widget.ViewPager
                android:id="@+id/recipient_select_pager"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </eightbitlab.com.blurview.BlurTarget>

        <com.android.common.view.MVSideFrame
            android:id="@+id/m_vertical_side_frame_top"
            android:layout_width="match_parent"
            android:layout_height="@dimen/tx_mv_side_top_frame_height"
            android:layout_gravity="top"
            app:autoUpdate="false" />

        <LinearLayout
            android:id="@+id/recipient_select_filter_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/tx_common_bg"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:elevation="0dp"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/recipient_select_filter_bar_child"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/tx_nest_bouncy_content_padding_top"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="@dimen/normal_margin"
                android:paddingTop="@dimen/small_margin"
                android:paddingEnd="@dimen/normal_margin">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <com.goodwy.commons.views.MyTextView
                        android:id="@+id/filter_recent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/ripple_all_corners"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:paddingStart="@dimen/normal_margin"
                        android:paddingTop="@dimen/small_margin"
                        android:paddingEnd="@dimen/normal_margin"
                        android:paddingBottom="@dimen/small_margin"
                        android:text="@string/call_log"
                        android:textSize="@dimen/normal_text_size"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:id="@+id/filter_recent_line"
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="@drawable/divider_settings"
                        app:layout_constraintBottom_toBottomOf="@id/filter_recent"
                        app:layout_constraintEnd_toEndOf="@id/filter_recent"
                        app:layout_constraintStart_toStartOf="@id/filter_recent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <com.goodwy.commons.views.MyTextView
                        android:id="@+id/filter_contacts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/ripple_all_corners"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:paddingStart="@dimen/normal_margin"
                        android:paddingTop="@dimen/small_margin"
                        android:paddingEnd="@dimen/normal_margin"
                        android:paddingBottom="@dimen/small_margin"
                        android:text="@string/contacts"
                        android:textSize="@dimen/normal_text_size"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:id="@+id/filter_contacts_line"
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="@drawable/divider_settings"
                        app:layout_constraintBottom_toBottomOf="@id/filter_contacts"
                        app:layout_constraintEnd_toEndOf="@id/filter_contacts"
                        app:layout_constraintStart_toStartOf="@id/filter_contacts" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="@dimen/normal_margin"
                android:background="@drawable/divider_settings" />
        </LinearLayout>

        <com.android.common.view.MAppBarLayout
            android:id="@+id/recipient_select_appbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/tx_top_bar_expand_height"
            android:background="@color/transparent"
            app:elevation="0dp"
            app:liftOnScroll="false"
            app:titleText="@string/select_contacts" />

        <com.android.common.view.MVSideFrame
            android:id="@+id/m_vertical_side_frame_bottom"
            android:layout_width="match_parent"
            android:layout_height="@dimen/tx_mv_side_bottom_frame_height"
            android:layout_gravity="bottom"
            app:autoUpdate="false"
            app:isTopFrame="false" />
    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <com.android.common.view.MRippleToolBar
        android:id="@+id/confirm_tab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center|bottom"
        android:layout_centerHorizontal="true" />

    
</FrameLayout>
