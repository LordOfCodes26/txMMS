<!--        app:layout_constraintEnd_toEndOf="parent"-->
<!--        app:layout_constraintStart_toStartOf="parent"-->
<!--        app:layout_constraintTop_toBottomOf="@id/choose_first_wrapper"-->
<!--        app:layout_constraintBottom_toBottomOf="parent"/>-->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="@dimen/small_md_margin"
        android:baselineAligned="false"
        android:orientation="horizontal"
        android:weightSum="4">

        <LinearLayout
            android:id="@+id/choose_image"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:contentDescription="@string/gallery_short">
            <ImageView
                android:id="@+id/choose_image_icon"
                android:layout_width="@dimen/chips_input_chip_row_height"
                android:layout_height="@dimen/chips_input_chip_row_height"
                android:layout_margin="@dimen/medium_normal_margin"
                android:background="?selectableItemBackgroundBorderless"
                android:contentDescription="@null"
                android:paddingHorizontal="@dimen/zero"
                android:layout_gravity="center_horizontal"
                android:src="@drawable/ic_sms_extra_image"
                app:rippleColor="?attr/colorControlHighlight" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/choose_image_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/small_margin"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/gallery_short"
                android:textAlignment="center"
                android:textColor="@color/default_text_color"
                android:textSize="@dimen/smaller_text_size"
                android:visibility="visible" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/choose_voice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:contentDescription="@string/voice_short">
            <ImageView
                android:id="@+id/choose_voice_icon"
                android:layout_width="@dimen/chips_input_chip_row_height"
                android:layout_height="@dimen/chips_input_chip_row_height"
                android:layout_margin="@dimen/medium_normal_margin"
                android:background="?selectableItemBackgroundBorderless"
                android:contentDescription="@null"
                android:paddingHorizontal="@dimen/zero"
                android:layout_gravity="center_horizontal"
                android:src="@drawable/ic_sms_extra_mic"
                app:rippleColor="?attr/colorControlHighlight" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/choose_voice_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/small_margin"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/voice_short"
                android:textAlignment="center"
                android:textColor="@color/default_text_color"
                android:textSize="@dimen/smaller_text_size"
                android:visibility="visible" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/choose_camera"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:contentDescription="@string/camera_short">
            <ImageView
                android:id="@+id/choose_camera_icon"
                android:layout_width="@dimen/chips_input_chip_row_height"
                android:layout_height="@dimen/chips_input_chip_row_height"
                android:layout_margin="@dimen/medium_normal_margin"
                android:background="?selectableItemBackgroundBorderless"
                android:contentDescription="@null"
                android:paddingHorizontal="@dimen/zero"
                android:layout_gravity="center_horizontal"
                android:src="@drawable/ic_sms_extra_camera"
                app:rippleColor="?attr/colorControlHighlight" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/choose_camera_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/small_margin"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/camera_short"
                android:textAlignment="center"
                android:textColor="@color/default_text_color"
                android:textSize="@dimen/smaller_text_size"
                android:visibility="visible" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/choose_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:contentDescription="@string/title">
            <ImageView
                android:id="@+id/choose_title_icon"
                android:layout_width="@dimen/chips_input_chip_row_height"
                android:layout_height="@dimen/chips_input_chip_row_height"
                android:layout_margin="@dimen/medium_normal_margin"
                android:background="?selectableItemBackgroundBorderless"
                android:contentDescription="@null"
                android:paddingHorizontal="@dimen/zero"
                android:layout_gravity="center_horizontal"
                android:gravity="center_horizontal"
                android:src="@drawable/ic_sms_extra_title"
                app:rippleColor="?attr/colorControlHighlight" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/choose_title_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/small_margin"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/title"
                android:textAlignment="center"
                android:textColor="@color/default_text_color"
                android:textSize="@dimen/smaller_text_size"
                android:visibility="visible" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
