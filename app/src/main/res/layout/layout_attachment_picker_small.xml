    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="@dimen/tx_cardview_padding_vertical"
        android:baselineAligned="false"
        android:orientation="horizontal"
        android:weightSum="4">

        <LinearLayout
            android:id="@+id/choose_clock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:contentDescription="@string/clock_short">

            <ImageView
                android:id="@+id/choose_clock_icon"
                android:layout_width="@dimen/chips_input_chip_row_height"
                android:layout_height="@dimen/chips_input_chip_row_height"
                android:background="?selectableItemBackgroundBorderless"
                android:layout_margin="@dimen/medium_normal_margin"
                android:contentDescription="@null"
                android:paddingHorizontal="@dimen/zero"
                android:layout_gravity="center_horizontal"
                android:src="@drawable/ic_sms_extra_clock"
                app:rippleColor="?attr/colorControlHighlight" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/choose_clock_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/small_margin"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/clock_short"
                android:textAlignment="center"
                android:textColor="@color/default_text_color"
                android:textSize="@dimen/smaller_text_size"
                android:visibility="visible" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/choose_emoji"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:contentDescription="@string/choose_emoji">
            
            <ImageView
                android:id="@+id/choose_emoji_icon"
                android:layout_width="@dimen/chips_input_chip_row_height"
                android:layout_height="@dimen/chips_input_chip_row_height"
                android:background="?selectableItemBackgroundBorderless"
                android:layout_margin="@dimen/medium_normal_margin"
                android:contentDescription="@null"
                android:paddingHorizontal="@dimen/zero"
                android:layout_gravity="center_horizontal"
                android:src="@drawable/ic_sms_extra_emoji"
                app:rippleColor="?attr/colorControlHighlight" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/choose_emoji_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/small_margin"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/choose_emoji"
                android:textAlignment="center"
                android:textColor="@color/default_text_color"
                android:textSize="@dimen/smaller_text_size"
                android:visibility="visible" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/choose_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:contentDescription="@string/quick_texts">

            <ImageView
                android:id="@+id/choose_text_icon"
                android:layout_width="@dimen/chips_input_chip_row_height"
                android:layout_height="@dimen/chips_input_chip_row_height"
                android:background="?selectableItemBackgroundBorderless"
                android:layout_margin="@dimen/medium_normal_margin"
                android:contentDescription="@null"
                android:paddingHorizontal="@dimen/zero"
                android:layout_gravity="center_horizontal"
                android:src="@drawable/ic_sms_extra_word"
                app:rippleColor="?attr/colorControlHighlight" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/choose_text_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/small_margin"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/quick_texts"
                android:textAlignment="center"
                android:textColor="@color/default_text_color"
                android:textSize="@dimen/smaller_text_size"
                android:visibility="visible" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/choose_contact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:contentDescription="@string/contacts_tab">
            <ImageView
                android:id="@+id/choose_contact_icon"
                android:layout_width="@dimen/chips_input_chip_row_height"
                android:layout_height="@dimen/chips_input_chip_row_height"
                android:layout_margin="@dimen/medium_normal_margin"
                android:background="?selectableItemBackgroundBorderless"
                android:contentDescription="@null"
                android:paddingHorizontal="@dimen/zero"
                android:layout_gravity="center_horizontal"
                android:src="@drawable/ic_sms_extra_contact"
                app:rippleColor="?attr/colorControlHighlight" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/choose_contact_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/small_margin"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/contacts_tab"
                android:textAlignment="center"
                android:textColor="@color/default_text_color"
                android:textSize="@dimen/smaller_text_size"
                android:visibility="visible" />
        </LinearLayout>

    </LinearLayout>

<!--    <androidx.constraintlayout.helper.widget.Flow-->
<!--        android:id="@+id/choose_second_wrapper"-->
<!--        android:layout_width="match_parent"-->
<!--        android:layout_height="wrap_content"-->
<!--        app:constraint_referenced_ids="choose_image,choose_voice,choose_camera,choose_title"-->
<!--        app:flow_verticalGap="@dimen/small_margin"-->
