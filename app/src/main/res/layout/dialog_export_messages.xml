<?xml version="1.0" encoding="utf-8"?>
<eightbitlab.com.blurview.BlurView
    android:id="@+id/blurView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@drawable/dialog_background_transparent">
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/normal_margin">

        <com.goodwy.commons.views.MyTextView
            android:id="@+id/dialog_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title"
            android:textColor="@color/tx_title_text"
            android:gravity="center_horizontal"
            style="@style/DialogTitleStyle"/>
    </RelativeLayout>

    <ScrollView
        android:id="@+id/export_messages_scrollview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/export_messages_holder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/tx_dialog_padding_horizontal"
            android:paddingTop="@dimen/normal_margin">

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/export_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/activity_margin"
                android:indeterminate="true"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:showAnimationBehavior="inward" />



            <LinearLayout
                android:id="@+id/export_sms_wrapper"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="@dimen/medium_margin">

                <TextView
                    android:id="@+id/label_export_sms_checkbox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/tx_content_text"
                    android:textSize="@dimen/tx_content_text"
                    android:text="@string/export_sms" />

                <com.android.common.view.MCheckBox
                    android:id="@+id/export_sms_checkbox"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:theme="@style/Theme.Common"
                    android:text=""/>


            </LinearLayout>

            <LinearLayout
                android:id="@+id/export_mms_wrapper"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="@dimen/medium_margin">

                <TextView
                    android:id="@+id/label_export_mms_checkbox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/tx_content_text"
                    android:textSize="@dimen/tx_content_text"
                    android:text="@string/export_mms" />

                <com.android.common.view.MCheckBox
                    android:id="@+id/export_mms_checkbox"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:theme="@style/Theme.Common"
                    android:text="" />
            </LinearLayout>


            <com.android.common.view.MEditText
                android:id="@+id/export_messages_filename"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/activity_margin"
                android:singleLine="true"
                android:textCursorDrawable="@null"
                android:textSize="@dimen/normal_text_size"
                android:layout_marginTop="@dimen/normal_activity_margin"
                tools:text="Messages" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/tx_dialog_padding_horizontal"
        android:layout_marginTop="-16dp"
        android:orientation="horizontal">

        <include layout="@layout/layout_confirm_tx_blur" />


    </LinearLayout>

</LinearLayout>
</eightbitlab.com.blurview.BlurView>
