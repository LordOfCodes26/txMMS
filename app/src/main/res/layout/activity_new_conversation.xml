<?xml version="1.0" encoding="utf-8"?>

<eightbitlab.com.blurview.BlurTarget
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainBlurTarget"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/conversation_wrapper"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <!-- Full-screen [ExpandedMessageFragment] must be a sibling of the coordinator (not inside it),
             matching activity_thread.xml, so hiding the coordinator does not hide the fragment host. -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

        <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:id="@+id/new_conversation_coordinator"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:clipToPadding="false">

            <eightbitlab.com.blurview.BlurTarget
                android:id="@+id/conversation_scroll_blur"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="@dimen/tx_blur_target_margin_top"
                android:background="@color/transparent">

                <!-- Chips stay pinned; query result panel fills remaining height and only its list scrolls. -->
                <LinearLayout
                    android:id="@+id/new_conversation_content"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:paddingHorizontal="@dimen/activity_padding_left_right">

                    <com.goodwy.commons.views.ChipsInputView
                        android:id="@+id/new_conversation_address"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:elevation="@dimen/cardview_default_elevation"
                        android:layout_marginStart="@dimen/tx_cardview_margin_horizontal"
                        android:layout_marginEnd="@dimen/tx_cardview_margin_horizontal" />

                    <ImageView
                        android:id="@+id/add_contact_divider"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/divider_height"
                        android:background="@color/divider_grey"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/suggestions_overlay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        android:orientation="vertical">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="@dimen/tx_cardview_margin_horizontal"
                            android:layout_marginTop="@dimen/tx_cardview_margin_vertical"
                            app:cardBackgroundColor="@color/tx_cardview_bg"
                            app:cardCornerRadius="@dimen/tx_cardview_corner_radius"
                            app:cardElevation="@dimen/cardview_default_elevation">
                            <HorizontalScrollView
                                android:id="@+id/suggestions_scrollview"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingTop="@dimen/tx_cardview_padding_vertical"
                                android:paddingBottom="@dimen/tx_cardview_item_padding_vertical"
                                android:paddingStart="@dimen/tx_cardview_padding_left"
                                android:paddingEnd="@dimen/tx_cardview_padding_left"
                                android:overScrollMode="never"
                                android:scrollbars="none">

                                <LinearLayout
                                    android:id="@+id/suggestions_holder"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:paddingStart="@dimen/normal_margin"
                                    android:paddingEnd="@dimen/normal_margin"
                                    android:divider="@drawable/linear_layout_horizontal_divider"
                                    android:orientation="horizontal"
                                    android:showDividers="middle" />

                            </HorizontalScrollView>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/new_conversation_holder"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:clipChildren="false"
                        android:clipToPadding="false">

                        <com.goodwy.commons.views.MyTextView
                            android:id="@+id/no_contacts_placeholder"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="top|center_horizontal"
                            android:background="@drawable/ripple_all_corners"
                            android:padding="@dimen/activity_margin"
                            android:alpha="0.8"
                            android:gravity="center"
                            android:text="@string/no_access_to_contacts"
                            android:textSize="@dimen/tx_normal_text"
                            android:visibility="gone" />

                        <com.goodwy.commons.views.MyTextView
                            android:id="@+id/no_contacts_placeholder_2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="top|center_horizontal"
                            android:background="@drawable/ripple_all_corners"
                            android:padding="@dimen/activity_margin"
                            android:alpha="0.8"
                            android:gravity="center"
                            android:text="@string/request_the_required_permissions"
                            android:textSize="@dimen/tx_normal_text"
                            android:visibility="gone" />

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/contacts_list_wrapper"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="@dimen/tx_cardview_margin_horizontal"
                            android:layout_marginVertical="@dimen/tx_cardview_margin_vertical"
                            android:visibility="gone"
                            app:contentPaddingBottom="@dimen/medium_margin"
                            app:contentPaddingTop="@dimen/medium_margin"
                            app:cardBackgroundColor="@color/tx_cardview_bg"
                            app:cardCornerRadius="@dimen/tx_cardview_corner_radius"
                            app:strokeColor="@color/tx_popup_menu_border"
                            app:strokeWidth="@dimen/cardview_stroke"
                            app:cardElevation="@dimen/cardview_default_elevation">
                            <com.goodwy.commons.views.MyRecyclerView
                                android:id="@+id/contacts_list"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:clipToPadding="false"
                                android:layoutAnimation="@anim/layout_animation"
                                android:nestedScrollingEnabled="true"
                                android:overScrollMode="ifContentScrolls"
                                android:scrollbars="none"
                                app:layoutManager="com.goodwy.commons.views.MyLinearLayoutManager" />
                        </com.google.android.material.card.MaterialCardView>

                    </FrameLayout>
                </LinearLayout>
            </eightbitlab.com.blurview.BlurTarget>

            <com.android.common.view.MAppBarLayout
                android:id="@+id/new_conversation_appbar"
                android:layout_width="match_parent"
                android:layout_height="@dimen/tx_top_bar_expand_height"
                android:background="@color/transparent"
                app:elevation="0dp"
                app:liftOnScroll="false"
                app:titleText="@string/new_conversation" />

        </androidx.coordinatorlayout.widget.CoordinatorLayout>

            <FrameLayout
                android:id="@+id/fragment_container"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

        </FrameLayout>

        <RelativeLayout
            android:id="@+id/message_holder_wrapper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:gravity="bottom">

            <include
                android:id="@+id/message_holder"
                layout="@layout/layout_thread_send_message_holder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </RelativeLayout>
    </LinearLayout>


    <!--    eightbitlab.com.blurview.BlurTarget-->
</eightbitlab.com.blurview.BlurTarget>
