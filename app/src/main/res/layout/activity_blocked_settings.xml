<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tx_common_bg">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/settings_coordinator"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/transparent"
        android:clipChildren="false"
        android:clipToPadding="false">

        <eightbitlab.com.blurview.BlurTarget
            android:id="@+id/mainBlurTarget"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="@dimen/tx_blur_target_margin_top"
            android:background="@color/tx_common_bg"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <com.android.common.nestbouncy.BouncyScrollView
                android:id="@+id/settingsNestedScrollview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:fillViewport="true"
                android:paddingTop="@dimen/tx_nest_bouncy_content_padding_top"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/settings_holder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="@dimen/filter_section_margin"
                    android:paddingTop="0dp">

                    <TextView
                        android:id="@+id/settingsNotificationsLabel"
                        style="@style/SettingsSectionLabelStyle"
                        android:text="@string/notifications" />

                    <androidx.cardview.widget.CardView
                        android:id="@+id/settingsNotificationsHolder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="@dimen/tx_cardview_margin_horizontal"
                        android:layout_marginVertical="@dimen/tx_cardview_margin_vertical"
                        app:cardBackgroundColor="@color/tx_cardview_bg"
                        app:cardCornerRadius="@dimen/tx_cardview_corner_radius"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:id="@+id/settingsNotificationsWrapper"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <RelativeLayout
                                android:id="@+id/settings_show_notification_holder"
                                style="@style/SettingsHolderSwitchStyle">

                                <com.goodwy.commons.views.MyTextView
                                    android:id="@+id/settingsShowNotificationLabel"
                                    style="@style/SettingsTextLabelStyle"
                                    android:layout_alignParentStart="true"
                                    android:layout_centerVertical="true"
                                    android:layout_toStartOf="@+id/settings_show_notification"
                                    android:text="@string/show_notification" />

                                <com.goodwy.commons.views.MyLiquidSwitch
                                    android:id="@+id/settings_show_notification"
                                    style="@style/SettingsSwitchStyle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_alignParentEnd="true"
                                    android:layout_centerVertical="true" />
                            </RelativeLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </com.android.common.nestbouncy.BouncyScrollView>
        </eightbitlab.com.blurview.BlurTarget>

        <com.android.common.view.MVSideFrame
            android:id="@+id/m_vertical_side_frame_top"
            android:layout_width="match_parent"
            android:layout_height="@dimen/tx_mv_side_top_frame_height"
            android:layout_alignParentTop="true"
            app:autoUpdate="false" />

        <com.android.common.view.MAppBarLayout
            android:id="@+id/settings_menu"
            android:layout_width="match_parent"
            android:layout_height="@dimen/tx_top_bar_expand_height"
            android:background="@color/transparent"
            app:elevation="0dp"
            app:liftOnScroll="false"
            app:titleText="@string/settings" />

        <com.android.common.view.MVSideFrame
            android:id="@+id/m_vertical_side_frame_bottom"
            android:layout_width="match_parent"
            android:layout_height="@dimen/tx_mv_side_bottom_frame_height"
            android:layout_gravity="bottom"
            app:autoUpdate="false"
            app:isTopFrame="false" />
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</FrameLayout>
