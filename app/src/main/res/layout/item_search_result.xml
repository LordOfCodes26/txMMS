<?xml version="1.0" encoding="utf-8"?>
<!-- Mirrors the conversation row inner content (item_conversation) for visual parity in main search. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/search_result_frame"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/theme_black_background_color">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/search_result_frame_select"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/recent_call_height"
        android:paddingStart="@dimen/tx_cardview_padding_left"
        android:paddingEnd="@dimen/tx_cardview_padding_right">

        <com.goodwy.commons.views.ContactAvatarView
            android:id="@+id/search_result_image"
            android:layout_width="@dimen/tx_cardview_icon_size"
            android:layout_height="@dimen/tx_cardview_icon_size"
            android:layout_marginEnd="@dimen/tx_cardview_icon_margin_right"
            android:contentDescription="@null"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/search_result_title_holder"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="start|bottom"
            android:layout_marginStart="@dimen/medium_normal_margin"
            android:layout_marginTop="@dimen/normal_margin"
            android:layout_marginEnd="@dimen/activity_margin"
            android:gravity="start|bottom"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/search_result_image"
            app:layout_constraintTop_toTopOf="parent">

            <com.goodwy.commons.views.MyTextView
                android:id="@+id/search_result_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textAlignment="viewStart"
                android:textDirection="firstStrongLtr"
                android:textSize="@dimen/tx_cardview_title_size"
                tools:text="John" />
        </LinearLayout>

        <ImageView
            android:id="@+id/search_result_message_type"
            android:layout_width="@dimen/list_icon_size_xx_small"
            android:layout_height="@dimen/list_icon_size_xx_small"
            android:layout_marginTop="@dimen/tx_cardview_card_title_margin_top"
            android:contentDescription="@null"
            android:scaleType="fitCenter"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="@+id/search_result_title_holder"
            app:layout_constraintTop_toBottomOf="@id/search_result_title_holder"
            tools:src="@drawable/ic_sms_out" />

        <com.goodwy.commons.views.MyTextView
            android:id="@+id/search_result_snippet"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/medium_margin"
            android:layout_marginEnd="@dimen/section_margin"
            android:ellipsize="end"
            android:maxLines="1"
            android:paddingTop="@dimen/tx_cardview_summary_padding_top"
            android:textSize="@dimen/tx_cardview_summary_size"
            app:layout_constraintEnd_toStartOf="@id/search_result_date"
            app:layout_constraintStart_toEndOf="@id/search_result_message_type"
            app:layout_constraintTop_toBottomOf="@id/search_result_title_holder"
            tools:ignore="RtlSymmetry"
            tools:text="Hey buddy!" />

        <com.goodwy.commons.views.MyTextView
            android:id="@+id/search_result_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/medium_md_margin"
            android:layout_marginEnd="@dimen/normal_margin"
            android:alpha="0.6"
            android:gravity="center_vertical"
            android:textSize="@dimen/smaller_text_size"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/search_result_title_holder"
            tools:text="13:30" />

        <ImageView
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1px"
            android:layout_marginEnd="@dimen/tiny_margin"
            android:alpha="0.2"
            android:background="@drawable/divider_settings"
            android:contentDescription="@null"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@id/search_result_date"
            app:layout_constraintStart_toStartOf="@+id/search_result_title_holder" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
