<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tx_common_bg">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/settings_coordinator"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/transparent"
        android:clipChildren="false"
        android:clipToPadding="false">

        <eightbitlab.com.blurview.BlurTarget
            android:id="@+id/mainBlurTarget"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="@dimen/tx_blur_target_margin_top"
            android:background="@color/tx_common_bg"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/manage_quick_texts_wrapper"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingStart="@dimen/activity_padding_left_right"
                android:paddingTop="@dimen/tx_nest_bouncy_content_padding_top"
                android:paddingEnd="@dimen/activity_padding_left_right"
                android:paddingBottom="@dimen/activity_margin"
                tools:context=".activities.ManageQuickTextsActivity">

                <androidx.cardview.widget.CardView
                    android:id="@+id/manage_quick_texts_card"
                    style="@style/SettingsSectionHolder"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:clipChildren="true"
                    android:clipToPadding="true"
                    app:cardBackgroundColor="@color/tx_cardview_bg"
                    app:cardElevation="0dp"
                    app:layout_constrainedHeight="true"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0">

                    <FrameLayout
                        android:id="@+id/manage_quick_texts_card_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent">

                        <com.goodwy.commons.views.MyRecyclerView
                            android:id="@+id/manage_quick_texts_list"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@android:color/transparent"
                            android:clipToPadding="true"
                            android:nestedScrollingEnabled="false"
                            android:paddingStart="@dimen/medium_margin"
                            android:paddingTop="@dimen/activity_margin"
                            android:paddingEnd="@dimen/medium_margin"
                            android:scrollbars="none"
                            android:visibility="gone"
                            app:layoutManager="com.goodwy.commons.views.MyLinearLayoutManager"
                            tools:listitem="@layout/item_manage_quick_text" />



                    </FrameLayout>

                </androidx.cardview.widget.CardView>

                <com.goodwy.commons.views.MyTextView
                    android:id="@+id/manage_quick_texts_placeholder"
                    android:layout_width="match_parent"
                    android:layout_height="450dp"
                    android:layout_gravity="center"
                    android:gravity="center_vertical|center_horizontal"
                    android:padding="@dimen/activity_margin"
                    android:text="@string/no_quick_texts"
                    android:lineSpacingMultiplier="1.2"
                    android:textSize="@dimen/tx_sub_section"
                    android:textColor="@color/txt_empty_sms"
                    android:visibility="visible"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </eightbitlab.com.blurview.BlurTarget>

        <com.android.common.view.MVSideFrame
            android:id="@+id/m_vertical_side_frame_top"
            android:layout_width="match_parent"
            android:layout_height="@dimen/tx_mv_side_top_frame_height"
            android:layout_gravity="top"
            app:autoUpdate="false" />

        <com.android.common.view.MAppBarLayout
            android:id="@+id/quick_texts_appbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/tx_top_bar_expand_height"
            android:background="@color/transparent"
            app:elevation="0dp"
            app:liftOnScroll="false"
            app:titleText="@string/manage_quick_texts" />

        <com.goodwy.commons.views.CustomActionModeToolbar
            android:id="@+id/quick_texts_action_mode_toolbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/tx_top_bar_toolbar_height"
            android:layout_marginTop="@dimen/tx_top_bar_toolbar_margin_top"
            android:background="@android:color/transparent"
            android:visibility="gone" />

        <com.android.common.view.MVSideFrame
            android:id="@+id/m_vertical_side_frame_bottom"
            android:layout_width="match_parent"
            android:layout_height="@dimen/tx_mv_side_bottom_frame_height"
            android:layout_gravity="bottom"
            app:autoUpdate="false"
            app:isTopFrame="false" />
    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <com.android.common.view.MRippleToolBar
        android:id="@+id/manage_quick_texts_add_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="@dimen/ripple_bottom"
        android:elevation="0dp"
        android:visibility="visible" />

    <com.android.common.view.MRippleToolBar
        android:id="@+id/action_mode_ripple_toolbar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="@dimen/ripple_bottom"
        android:elevation="0dp"
        android:visibility="gone" />

</FrameLayout>
