<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <eightbitlab.com.blurview.BlurTarget
        android:id="@+id/mainBlurTarget"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:id="@+id/main_coordinator"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/transparent">

            <eightbitlab.com.blurview.BlurTarget
                android:id="@+id/blurTarget"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/tx_common_bg"
                app:layout_behavior="@string/appbar_scrolling_view_behavior">

                <!-- txDial-style: NestedScrollView so Coordinator/AppBar gets nested scroll; single child required — FrameLayout holds list + overlay. -->
                <androidx.core.widget.NestedScrollView
                    android:id="@+id/conversations_nested_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:fillViewport="true"
                    android:scrollbars="none"
                    app:layout_behavior="@string/appbar_scrolling_view_behavior">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <com.goodwy.commons.views.MyRecyclerView
                            android:id="@+id/conversations_list"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:clipToPadding="false"
                            android:layoutAnimation="@anim/layout_animation"
                            android:scrollbars="none"
                            app:layoutManager="com.goodwy.commons.views.MyLinearLayoutManager" />

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginTop="-60dp">

                            <com.google.android.material.progressindicator.LinearProgressIndicator
                                android:id="@+id/conversations_progress_bar"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_alignParentTop="true"
                                android:indeterminate="true"
                                android:visibility="gone"
                                app:hideAnimationBehavior="outward"
                                app:showAnimationBehavior="inward"
                                app:showDelay="250"
                                tools:visibility="visible" />

                            <ImageView
                                android:id="@+id/no_conversations_placeholder"
                                android:layout_width="86dp"
                                android:layout_height="80dp"
                                android:layout_centerInParent="true"
                                android:contentDescription="@null"
                                android:scaleType="fitCenter"
                                android:gravity="center"
                                android:src="@drawable/ic_no_sms"
                                android:visibility="gone"
                                tools:visibility="visible" />

                            <com.goodwy.commons.views.MyTextView
                                android:id="@+id/no_conversations_placeholder_2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_below="@+id/no_conversations_placeholder"
                                android:layout_centerHorizontal="true"
                                android:gravity="center"
                                android:padding="@dimen/activity_margin"
                                android:text="@string/no_conversations_found"
                                android:textSize="@dimen/tx_sub_section"
                                android:textColor="@color/txt_empty_sms"
                                android:visibility="visible"
                                tools:visibility="visible" />

                        </RelativeLayout>

                    </FrameLayout>
                </androidx.core.widget.NestedScrollView>

                <RelativeLayout
                    android:id="@+id/search_holder"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:alpha="0"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:id="@+id/search_placeholder_img"
                            android:layout_width="86dp"
                            android:layout_height="80dp"
                            android:layout_centerInParent="true"
                            android:contentDescription="@null"
                            android:scaleType="fitCenter"
                            android:gravity="center"
                            android:src="@drawable/ic_no_sms"
                            android:visibility="visible"
                            tools:visibility="gone" />

                        <com.goodwy.commons.views.MyTextView
                            android:id="@+id/search_placeholder"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@+id/search_placeholder_img"
                            android:layout_centerHorizontal="true"
                            android:gravity="center"
                            android:padding="@dimen/activity_margin"
                            android:text="@string/no_search_conversations_found"
                            android:textSize="@dimen/tx_sub_section"
                            android:textColor="@color/txt_empty_sms"
                            android:visibility="gone" />

                        <com.goodwy.commons.views.MyTextView
                            android:id="@+id/search_placeholder_2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@+id/search_placeholder_img"
                            android:layout_centerHorizontal="true"
                            android:gravity="center"
                            android:padding="@dimen/activity_margin"
                            android:text="@string/type_2_characters"
                            android:textSize="@dimen/tx_sub_section"
                            android:textColor="@color/txt_empty_sms"
                            android:visibility="gone"
                            tools:visibility="gone" />

                    </RelativeLayout>

                    <androidx.core.widget.NestedScrollView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:fillViewport="true"
                        android:scrollbars="none">

                        <com.goodwy.commons.views.MyRecyclerView
                            android:id="@+id/search_results_list"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:clipToPadding="false"
                            android:scrollbars="vertical"
                            app:layoutManager="com.goodwy.commons.views.MyLinearLayoutManager" />
                    </androidx.core.widget.NestedScrollView>
                </RelativeLayout>
            </eightbitlab.com.blurview.BlurTarget>

            <com.android.common.view.MVSideFrame
                android:id="@+id/m_vertical_side_frame_top"
                android:layout_width="match_parent"
                android:layout_height="@dimen/tx_mv_side_top_frame_height"
                android:layout_alignParentTop="true"/>

            <com.goodwy.commons.views.MySearchMenu
                android:id="@+id/main_menu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/transparent"
                android:paddingBottom="0dp" />

            <com.android.common.view.MVSideFrame
                android:id="@+id/m_vertical_side_frame_bottom"
                android:layout_width="match_parent"
                android:layout_height="@dimen/tx_mv_side_bottom_frame_height"
                android:layout_gravity="bottom"
                app:isTopFrame="false"/>


            <com.goodwy.commons.views.MyFloatingActionButton
                android:id="@+id/conversations_fab"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_marginBottom="@dimen/scroll_number_picker_item_height"
                android:layout_marginRight="@dimen/tx_actionBar_height"
                android:contentDescription="@string/new_conversation"
                android:src="@drawable/ic_plus_vector"
                app:applyWindowInsets="true"
                app:elevation="0dp"/>

        </androidx.coordinatorlayout.widget.CoordinatorLayout>

    </eightbitlab.com.blurview.BlurTarget>

    <FrameLayout
        android:id="@+id/lyt_action"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginLeft="15dp"
        android:layout_marginRight="15dp"
        android:layout_marginBottom="@dimen/ripple_bottom">
        <com.android.common.view.MRippleToolBar
            android:id="@+id/action_mode_ripple_toolbar"
            android:layout_gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="visible"/>
    </FrameLayout>


</FrameLayout>

