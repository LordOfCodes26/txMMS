<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/manage_quick_text_holder"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <RelativeLayout
        android:id="@+id/quick_text_item_wrapper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/tiny_margin"
        android:clickable="true"
        android:focusable="true">

        <com.goodwy.commons.views.MyTextView
            android:id="@+id/manage_quick_text_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/medium_margin"
            android:layout_marginTop="@dimen/tx_cardview_card_title_margin_top"
            android:layout_marginEnd="@dimen/larger_margin"
            android:layout_marginBottom="@dimen/tx_cardview_card_title_margin_top"
            android:textSize="@dimen/tx_normal_text"
            android:layout_toStartOf="@+id/quick_text_end_container" />

        <FrameLayout
            android:id="@+id/quick_text_end_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/tx_cardview_card_title_margin_top"
            android:paddingStart="@dimen/medium_margin"
            android:layout_alignParentEnd="true">

            <ImageView
                android:id="@+id/overflow_menu_icon"
                style="@style/OverflowEditIconStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_marginEnd="@dimen/smaller_margin"
                tools:ignore="ContentDescription" />

            <com.android.common.view.MCycleCheckBox
                android:id="@+id/quick_text_checkbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_marginEnd="@dimen/smaller_margin"
                android:paddingHorizontal="@dimen/small_margin"
                android:clickable="true"
                android:focusable="false"
                android:visibility="gone"
                tools:visibility="visible" />
        </FrameLayout>

    </RelativeLayout>
    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="@dimen/tx_cardview_divider_thickness"
        android:layout_marginStart="@dimen/medium_margin"
        android:layout_marginEnd="@dimen/medium_margin"
        android:background="@color/tx_cardview_divider"/>
</RelativeLayout>

