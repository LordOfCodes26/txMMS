<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/manage_quick_text_holder"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/tiny_margin"
    android:clickable="true"
    android:focusable="true">

    <com.goodwy.commons.views.MyTextView
        android:id="@+id/manage_quick_text_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:layout_marginStart="@dimen/bigger_margin"
        android:layout_marginTop="@dimen/normal_margin"
        android:layout_marginEnd="@dimen/activity_margin"
        android:layout_marginBottom="@dimen/normal_margin"
        android:layout_toStartOf="@+id/quick_text_end_container" />

    <FrameLayout
        android:id="@+id/quick_text_end_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true">

        <ImageView
            android:id="@+id/overflow_menu_icon"
            style="@style/OverflowEditIconStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical|end"
            android:layout_marginEnd="@dimen/smaller_margin"
            tools:ignore="ContentDescription" />

        <com.android.common.view.MCycleCheckBox
            android:id="@+id/quick_text_checkbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical|end"
            android:layout_marginEnd="@dimen/smaller_margin"
            android:clickable="true"
            android:focusable="false"
            android:visibility="gone"
            tools:visibility="visible" />
    </FrameLayout>

</RelativeLayout>

