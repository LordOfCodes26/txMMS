<?xml version="1.0" encoding="utf-8"?>
<!-- Mirrors txDial item_recent_call.xml; info holder replaced with picker checkbox. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/itemRecentsHolder"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:foreground="@drawable/selector">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/item_recents_frame"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/recent_call_height"
        android:paddingStart="@dimen/tx_cardview_padding_left"
        android:paddingEnd="@dimen/tx_cardview_padding_right">

        <FrameLayout
            android:id="@+id/item_recents_avatar_holder"
            android:layout_width="@dimen/call_icon_size"
            android:layout_height="@dimen/call_icon_size"
            android:layout_marginEnd="@dimen/tx_cardview_icon_margin_right"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.goodwy.commons.views.ContactAvatarView
                android:id="@+id/item_recents_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null" />

            <ImageView
                android:id="@+id/item_recents_avatar_sim_badge"
                android:layout_width="@dimen/list_icon_size_xx_small"
                android:layout_height="@dimen/list_icon_size_xx_small"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="@dimen/tiny_margin"
                android:layout_marginBottom="@dimen/tiny_margin"
                android:contentDescription="@null"
                android:scaleType="fitCenter"
                android:visibility="gone"
                tools:src="@drawable/ic_sim_one" />

        </FrameLayout>


        <TextView
            android:id="@+id/item_recents_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/medium_normal_margin"
            android:layout_marginTop="@dimen/normal_margin"
            android:gravity="start|bottom"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAlignment="viewStart"
            android:textDirection="firstStrongLtr"
            android:textSize="@dimen/bigger_text_size"
            app:layout_constraintBottom_toTopOf="@+id/item_recents_type"
            app:layout_constraintStart_toEndOf="@+id/item_recents_avatar_holder"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="PrivateResource"
            tools:text="John Doe" />

        <TextView
            android:id="@+id/item_recents_call_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/small_margin"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAlignment="viewStart"
            android:textDirection="firstStrongLtr"
            android:textSize="@dimen/smaller_text_size"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="@id/item_recents_name"
            app:layout_constraintStart_toEndOf="@+id/item_recents_name"
            tools:text="" />

        <ImageView
            android:id="@+id/item_recents_type"
            android:layout_width="@dimen/list_icon_size_xx_small"
            android:layout_height="@dimen/list_icon_size_xxx_small"
            android:layout_marginTop="@dimen/tx_cardview_card_title_margin_top"
            android:contentDescription="@null"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_cmn_out"
            app:layout_constraintTop_toBottomOf="@id/item_recents_name"
            app:layout_constraintStart_toStartOf="@+id/item_recents_name" />

        <RelativeLayout
            android:id="@+id/sim_wrapper"
            android:layout_width="@dimen/list_icon_size_xx_small"
            android:layout_height="@dimen/list_icon_size_xx_small"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginStart="@dimen/small_margin"
            app:layout_constraintTop_toTopOf="@id/item_recents_type"
            app:layout_constraintBottom_toBottomOf="@id/item_recents_type"
            app:layout_constraintStart_toEndOf="@+id/item_recents_type">
            <ImageView
                android:id="@+id/item_recents_sim_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/ic_cmn_sim"
                android:visibility="visible"
                android:backgroundTint="@color/red_call"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/item_recents_sim_id"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="@color/md_grey_white"
                android:textSize="@dimen/md_tiny_text_size"
                android:visibility="visible"
                android:text="1"/>
        </RelativeLayout>


        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/item_recents_sim_barrier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="start"
            app:constraint_referenced_ids="item_recents_name" />

        <TextView
            android:id="@+id/item_recents_number"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/small_margin"
            android:alpha="0.7"
            android:ellipsize="end"
            android:lines="1"
            android:textSize="@dimen/smaller_text_size"
            app:layout_constraintBottom_toBottomOf="@+id/item_recents_type"
            app:layout_constraintEnd_toStartOf="@+id/item_recents_date_time"
            app:layout_constraintStart_toEndOf="@+id/sim_wrapper"
            app:layout_constraintTop_toTopOf="@+id/item_recents_type"
            tools:text="+12345678901" />

        <TextView
            android:id="@+id/item_recents_date_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/medium_margin"
            android:alpha="0.6"
            android:gravity="center|end"
            android:lineSpacingExtra="@dimen/smaller_margin"
            android:maxLines="2"
            android:textSize="@dimen/smaller_text_size"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/cb_contact_select"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="31.12" />

        <com.android.common.view.MCycleCheckBox
            android:id="@+id/cb_contact_select"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/medium_margin"
            android:layout_marginEnd="@dimen/smaller_margin"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1px"
            android:layout_marginEnd="@dimen/tiny_margin"
            android:alpha="0.2"
            android:background="@drawable/divider_settings"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@+id/cb_contact_select"
            app:layout_constraintStart_toStartOf="@+id/item_recents_name"
            tools:ignore="ContentDescription" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
