<?xml version="1.0" encoding="utf-8"?>
<com.android.common.view.MBlurView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/blurView"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/dialog_title"
            style="@style/DialogTitleStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/tx_main_letter"
            android:layout_gravity="center"
            android:visibility="gone" />

        <ScrollView
            android:id="@+id/dialog_radio_holder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/tx_dialog_padding_horizontal">

            <RadioGroup
                android:id="@+id/dialog_radio_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        </ScrollView>

        <include
            android:id="@+id/dialog_radio_holder_divider"
            layout="@layout/divider" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/tx_dialog_padding_horizontal"
            android:orientation="horizontal">

            <include layout="@layout/layout_confirm_tx_blur" />


        </LinearLayout>
    </LinearLayout>
</com.android.common.view.MBlurView>
