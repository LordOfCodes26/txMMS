<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/item_contact_frame"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/selector_clickable"
    android:clickable="true"
    android:focusable="true"
    android:foreground="@drawable/selector">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/item_contact_holder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/recent_call_height"
        android:paddingStart="@dimen/bigger_margin"
        android:paddingEnd="@dimen/medium_margin">

        <com.goodwy.commons.views.ContactAvatarView
            android:id="@+id/item_contact_image"
            android:layout_width="@dimen/call_icon_size"
            android:layout_height="@dimen/call_icon_size"
            android:layout_marginEnd="@dimen/normal_margin"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/item_contact_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/medium_normal_margin"
            android:layout_marginTop="@dimen/smaller_margin"
            android:ellipsize="end"
            android:maxLines="1"
            android:textDirection="locale"
            android:textSize="@dimen/middle_text_size"
            tools:text="John Doe"
            app:layout_goneMarginBottom="@dimen/medium_margin"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/item_contact_number"
            app:layout_constraintStart_toEndOf="@+id/item_contact_image"
            app:layout_constraintEnd_toStartOf="@+id/item_contact_sim_image" />

        <ImageView
            android:id="@+id/item_contact_sim_image"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginStart="@dimen/small_margin"
            android:src="@drawable/ic_sim_vector"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@+id/item_contact_name"
            app:layout_constraintStart_toEndOf="@+id/item_contact_name"
            app:layout_constraintTop_toTopOf="@+id/item_contact_name"
            app:layout_constraintEnd_toStartOf="@+id/item_contact_info_holder" />

        <TextView
            android:id="@+id/item_contact_number"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/medium_margin"
            android:layout_marginBottom="@dimen/medium_margin"
            android:alpha="0.6"
            android:maxLines="1"
            android:textSize="@dimen/normal_text_size"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/item_contact_info_holder"
            app:layout_constraintStart_toEndOf="@+id/item_contact_image"
            app:layout_constraintTop_toBottomOf="@+id/item_contact_name"
            tools:text="0123 456 789" />

        <RelativeLayout
            android:id="@+id/item_contact_info_holder"
            android:layout_width="@dimen/action_mode_info_holder_size"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/small_margin"
            android:layout_marginStart="@dimen/medium_margin"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/details"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/item_contact_info"
                style="?attr/borderlessButtonStyle"
                android:layout_width="@dimen/recent_call_info_size"
                android:layout_height="@dimen/recent_call_info_size"
                android:layout_margin="@dimen/medium_md_margin"
                android:paddingHorizontal="@dimen/zero"
                app:icon="@drawable/ic_cmn_info"
                app:rippleColor="?attr/colorControlHighlight" />

            <com.goodwy.commons.views.MyAppCompatCheckbox
                android:id="@+id/item_contact_checkbox"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_centerInParent="true"
                android:visibility="gone" />
        </RelativeLayout>

        <ImageView
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1px"
            android:layout_marginEnd="@dimen/activity_margin"
            android:background="@drawable/divider_settings"
            android:alpha="0.2"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@+id/item_contact_name"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
