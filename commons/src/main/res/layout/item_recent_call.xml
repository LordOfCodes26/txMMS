<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/itemRecentsHolder"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true"
    android:foreground="@drawable/selector">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/itemRecentsFrameSelect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/recent_call_height"
        android:paddingStart="@dimen/activity_margin"
        android:paddingEnd="@dimen/normal_margin">

        <com.goodwy.commons.views.ContactAvatarView
            android:id="@+id/item_recents_image"
            android:layout_width="@dimen/call_icon_size"
            android:layout_height="@dimen/call_icon_size"
            android:layout_marginEnd="@dimen/normal_margin"
            android:contentDescription="@null"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/item_recents_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/medium_normal_margin"
            android:layout_marginTop="@dimen/normal_margin"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAlignment="viewStart"
            android:textDirection="firstStrongLtr"
            android:textSize="@dimen/tx_normal_text"
            app:layout_constrainedWidth="true"
            app:layout_constraintBottom_toTopOf="@+id/item_recents_type"
            app:layout_constraintEnd_toStartOf="@+id/item_recents_call_count"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toEndOf="@+id/item_recents_image"
            app:layout_goneMarginStart="0dp"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="PrivateResource"
            tools:text="John Doe" />

        <TextView
            android:id="@+id/item_recents_call_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/small_margin"
            android:layout_marginEnd="@dimen/small_margin"
            android:layout_marginBottom="@dimen/tiny_margin"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAlignment="viewStart"
            android:textDirection="firstStrongLtr"
            android:textSize="@dimen/tx_small_text"
            app:layout_constraintBottom_toBottomOf="@id/item_recents_name"
            app:layout_constraintEnd_toStartOf="@+id/item_recents_date_time"
            app:layout_constraintStart_toEndOf="@+id/item_recents_name"
            tools:text="(10)" />

        <ImageView
            android:id="@+id/item_recents_type"
            android:layout_width="@dimen/list_icon_size_xxx_small"
            android:layout_height="@dimen/list_icon_size_xxx_small"
            android:layout_marginBottom="@dimen/normal_margin"
            android:contentDescription="@null"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_cmn_out"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@+id/item_recents_name" />

        <ImageView
            android:id="@+id/item_recents_sim_image"
            android:layout_width="@dimen/list_icon_size_xx_small"
            android:layout_height="@dimen/list_icon_size_xx_small"
            android:layout_marginHorizontal="@dimen/smaller_margin"
            android:layout_marginStart="@dimen/larger_margin"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_cmn_sim"
            app:layout_constraintBottom_toBottomOf="@+id/item_recents_type"
            app:layout_constraintStart_toStartOf="@+id/item_recents_name"
            app:layout_constraintTop_toTopOf="@+id/item_recents_type"
            tools:ignore="ContentDescription" />

        <TextView
            android:id="@+id/item_recents_sim_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/md_grey_white"
            android:textSize="@dimen/md_tiny_text_size"
            app:layout_constraintBottom_toBottomOf="@+id/item_recents_sim_image"
            app:layout_constraintEnd_toEndOf="@+id/item_recents_sim_image"
            app:layout_constraintStart_toStartOf="@+id/item_recents_sim_image"
            app:layout_constraintTop_toTopOf="@+id/item_recents_sim_image"
            tools:text="1" />

        <!-- Barrier so when SIM icon is GONE, number starts after call type icon -->
        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/item_recents_sim_barrier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="end"
            app:constraint_referenced_ids="item_recents_type,item_recents_sim_image" />

        <TextView
            android:id="@+id/item_recents_number"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/small_margin"
            android:ellipsize="end"
            android:lines="1"
            android:textSize="@dimen/tx_small_text"
            app:layout_constraintBottom_toBottomOf="@+id/item_recents_type"
            app:layout_constraintEnd_toStartOf="@+id/item_recents_date_time"
            app:layout_constraintStart_toEndOf="@+id/item_recents_sim_barrier"
            app:layout_constraintTop_toTopOf="@+id/item_recents_type"
            tools:text="+12345678901" />

        <TextView
            android:id="@+id/item_recents_date_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/medium_margin"
            android:gravity="center|end"
            android:lineSpacingExtra="@dimen/smaller_margin"
            android:maxLines="2"
            android:textSize="@dimen/tx_small_text"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/item_recents_info_holder"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="31.12" />

        <RelativeLayout
            android:id="@+id/item_recents_info_holder"
            android:layout_width="@dimen/action_mode_info_holder_size"
            android:layout_height="@dimen/action_mode_info_holder_size"
            android:contentDescription="@string/details"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <RelativeLayout
                android:id="@+id/item_recents_info"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:layout_width="@dimen/recent_call_info_size"
                    android:layout_height="@dimen/recent_call_info_size"
                    android:layout_centerInParent="true"
                    android:src="@drawable/ic_cmn_info"
                    app:tint="@color/tx_main_blue" />

            </RelativeLayout>

            <com.android.common.view.MCycleCheckBox
                android:id="@+id/item_recents_checkbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:visibility="gone" />
        </RelativeLayout>

        <ImageView
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1px"
            android:layout_marginEnd="@dimen/small_margin"
            android:background="@drawable/divider_settings"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/item_recents_name"
            tools:ignore="ContentDescription" />

        <View
            android:id="@+id/overflow_menu_anchor"
            style="@style/OverflowMenuAnchorStyle"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
