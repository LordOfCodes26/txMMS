<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:baselineAligned="false"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <TextView
        android:id="@+id/dialog_radio_item_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textAlignment="viewStart"
        android:textDirection="locale"
        android:layout_marginStart="@dimen/tx_dialog_padding_horizontal"
        android:textSize="@dimen/tx_dialog_content"/>

    <com.android.common.view.MRadioButton
        android:id="@+id/dialog_radio_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:buttonTint="@color/tx_main_blue"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>
