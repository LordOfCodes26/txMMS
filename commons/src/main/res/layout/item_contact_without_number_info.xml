<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/item_contact_frame"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/selector_clickable"
    android:clickable="true"
    android:focusable="true"
    android:foreground="@drawable/selector">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/recent_call_height"
        android:paddingStart="@dimen/activity_margin"
        android:paddingEnd="@dimen/normal_margin">

        <com.goodwy.commons.views.ContactAvatarView
            android:id="@+id/item_contact_image"
            android:layout_width="@dimen/call_icon_size"
            android:layout_height="@dimen/call_icon_size"
            android:layout_marginEnd="@dimen/normal_margin"
            android:contentDescription="@null"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"  />

        <TextView
            android:id="@+id/item_contact_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/medium_normal_margin"
            android:ellipsize="end"
            android:maxLines="1"
            android:paddingEnd="@dimen/activity_margin"
            android:textDirection="locale"
            android:textSize="@dimen/tx_normal_text"
            tools:text="John Doe"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/item_contact_image"
            app:layout_constraintEnd_toStartOf="@+id/item_contact_info_holder" />

        <RelativeLayout
            android:id="@+id/item_contact_info_holder"
            android:layout_width="@dimen/action_mode_info_holder_size"
            android:layout_height="@dimen/action_mode_info_holder_size"
            android:contentDescription="@string/details"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.android.common.view.MCycleCheckBox
                android:id="@+id/item_contact_checkbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:visibility="gone" />
        </RelativeLayout>

        <ImageView
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1px"
            android:layout_marginEnd="@dimen/small_margin"
            android:background="@drawable/divider_settings"
            android:alpha="0.2"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@+id/item_contact_name"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
