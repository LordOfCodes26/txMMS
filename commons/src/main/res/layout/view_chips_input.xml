<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/normal_margin"
    android:paddingVertical="@dimen/medium_margin"
    app:cardBackgroundColor="@color/white"
    app:contentPaddingLeft="@dimen/normal_margin"
    app:contentPaddingRight="@dimen/normal_margin"
    app:contentPaddingBottom="@dimen/medium_margin"
    app:contentPaddingTop="@dimen/medium_margin"
    app:cardCornerRadius="26dp"
    app:strokeColor="@color/black"
    app:strokeWidth="0.5dp"
    app:cardElevation="4dp">

    <!-- MaxHeightScrollView clamps height so chips/text scroll instead of expanding the screen.
         fillViewport=false so chips_edit_wrapper stays compact when empty (no stretch to viewport). -->
    <com.goodwy.commons.views.MaxHeightScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="@dimen/two_line_list_item_min_height"
        android:fillViewport="false"
        android:scrollbars="none"
        android:overScrollMode="ifContentScrolls">

        <com.google.android.flexbox.FlexboxLayout
            android:id="@+id/chips_flex_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/two_line_list_item_min_height"
            android:clickable="true"
            android:focusable="true"
            app:flexWrap="wrap"
            app:flexDirection="row"
            app:alignItems="flex_start"
            app:alignContent="flex_start">

            <!-- Trailing text input: chips appear to its left (iPhone-style).
                 When remaining space is less than minWidth, wrapper wraps to next line. -->
            <RelativeLayout
                android:id="@+id/chips_edit_wrapper"
                android:layout_width="0dp"
                android:layout_height="@dimen/chips_input_chip_row_height"
                app:layout_flexGrow="1"
                app:layout_flexShrink="0"
                app:layout_minWidth="120dp"
                app:layout_alignSelf="flex_start">

                <com.goodwy.commons.views.MyEditText
                    android:id="@+id/chips_edit_text"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/chips_input_chip_row_height"
                    android:layout_centerVertical="true"
                    android:minWidth="@dimen/line_color_picker_height"
                    android:minLines="1"
                    android:paddingHorizontal="@dimen/tx_bottom_bar_icon_padding"
                    android:background="@android:color/transparent"
                    android:gravity="center_vertical"
                    android:hint=""
                    android:inputType="text|textMultiLine"
                    android:maxLines="2"
                    android:textSize="@dimen/normal_text_size"
                    android:textCursorDrawable="@null" />

                <ImageView
                    android:id="@+id/chips_clear_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignTop="@+id/chips_edit_text"
                    android:layout_alignEnd="@+id/chips_edit_text"
                    android:layout_marginStart="@dimen/small_margin"
                    android:layout_marginEnd="@dimen/medium_margin"
                    android:background="?selectableItemBackgroundBorderless"
                    android:alpha="0.4"
                    android:contentDescription="@string/delete"
                    android:src="@drawable/ic_clear_round"
                    android:visibility="gone"
                    tools:tint="@color/dark_grey" />

            </RelativeLayout>

        </com.google.android.flexbox.FlexboxLayout>
    </com.goodwy.commons.views.MaxHeightScrollView>

    <!-- Buttons at top right - clickable=false so touches pass through to edit text below -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:clickable="false"
        android:focusable="false">

        <ImageView
            android:id="@+id/chips_address_book_button"
            android:layout_width="@dimen/tx_cardview_icon_size"
            android:layout_height="@dimen/tx_cardview_icon_size"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="@string/search_contacts"
            android:src="@drawable/ic_cmn_contact_add"
            android:visibility="visible"
            android:padding="@dimen/tiny_margin"
            tools:tint="@color/dark_grey" />

        <ImageView
            android:id="@+id/chips_speech_to_text_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?selectableItemBackgroundBorderless"
            android:alpha="0.4"
            android:contentDescription="@string/delete"
            android:src="@drawable/ic_microphone_vector"
            android:visibility="gone"
            android:padding="@dimen/tiny_margin"
            tools:tint="@color/dark_grey" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
